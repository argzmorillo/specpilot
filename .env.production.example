# PostgreSQL
POSTGRES_DB=specpilot
POSTGRES_USER=specpilot
POSTGRES_PASSWORD=change-me

# Backend database connection
DATABASE_URL=postgresql://specpilot:change-me@postgres:5432/specpilot?schema=public

# Backend application
NODE_ENV=production
PORT=3000

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

# Keycloak / OIDC
KEYCLOAK_ISSUER_URL=http://localhost:8080/realms/specpilot
KEYCLOAK_JWKS_URI=http://keycloak:8080/realms/specpilot/protocol/openid-connect/certs
KEYCLOAK_CLIENT_ID=specpilot-api

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:4200

# Keycloak admin
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=admin1234