{
  "name": "specpilot",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "lint:backend": "eslint -c backend/eslint.config.js \"backend/**/*.ts\"",
    "lint:frontend": "eslint -c frontend/eslint.config.js \"frontend/**/*.{ts,html}\"",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "prettier": "^3.0.0",
    "typescript-eslint": "^8.0.0"
  }
}
